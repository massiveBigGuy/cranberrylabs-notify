# Proxmox API connection
# Point at any one node — it accesses the cluster API from there
PROXMOX_BASE_URL=<your URL>
PROXMOX_TOKEN_ID=<chosen tokenID>@pam!<name>token
PROXMOX_TOKEN_SECRET=<secret>

# Poll interval in milliseconds (default: 30000 = 30s)
POLL_INTERVAL_MS=30000

# Resource alert thresholds (percentage)
THRESHOLD_CPU=85
THRESHOLD_MEMORY=90
THRESHOLD_DISK=90

# SMTP config (Phase 2)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=notify@yourdomain
# SMTP_TO=user@example.com

# Digest schedule — cron expression (Phase 2)
# DIGEST_CRON=0 8 * * *
